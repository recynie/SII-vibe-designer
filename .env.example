# ------------------------------------------------------------
# OpenAI 兼容接口（文生图 GPT-image-2 + 备用 LLM）
# 在 https://www.findcg.com/ 或类似中转站获取 sk-xxx key
# ------------------------------------------------------------
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_IMAGES_URL=https://your-openai-relay.example.com/v1/images/generations
OPENAI_IMAGE_EDITS_URL=https://your-openai-relay.example.com/v1/images/edits
OPENAI_API_KEY=sk-REPLACE_WITH_YOUR_KEY
OPENAI_BASE_URL=https://your-openai-relay.example.com/

# ------------------------------------------------------------
# MiniMax（LLM + 图像生成开发后端）
# Token Plan Key：在 https://platform.minimax.io/ Billing > Token Plan 获取
# 注意：Token Plan Key 与 pay-as-you-go API Key 不通用
# ------------------------------------------------------------
MINIMAX_API_KEY=REPLACE_WITH_YOUR_TOKEN_PLAN_KEY
MINIMAX_BASE_URL=https://api.minimaxi.com

# ------------------------------------------------------------
# 图像生成后端切换（默认 openai 用于交付，minimax 用于开发省钱）
# ------------------------------------------------------------
# DESIGN_IMAGE_BACKEND=minimax
DESIGN_IMAGE_BACKEND=openai
