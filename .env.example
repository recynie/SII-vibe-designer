# ------------------------------------------------------------
# opencode 专用环境变量模板
# ------------------------------------------------------------
# 使用方式：复制为 .env，并按需同步到 vibe-design/.env。
# e2e runner 默认显式加载 vibe-design/.env。
# 交互式 opencode 推荐在 vibe-design/ 目录启动，因此也会读取 vibe-design/.env。
# Python 脚本凭据走 api.toml，不读取 .env。
# ------------------------------------------------------------

# SII (夏令营商用API) — opencode provider: sii-openai
OPENAI_API_KEY=sk-REPLACE_WITH_SII_KEY
SII_API_KEY=sk-REPLACE_WITH_SII_KEY

# MiniMax provider（备用）
MINIMAX_API_KEY=REPLACE_WITH_MINIMAX_TOKEN_PLAN_KEY

# FindCG OpenAI-compatible provider — opencode provider: findcg-openai
FINDCG_OPENAI_API_KEY=sk-REPLACE_WITH_FINDCG_OPENAI_KEY

# FindCG Claude provider — opencode provider: findcg-claude
FINDCG_CLAUDE_API_KEY=sk-REPLACE_WITH_FINDCG_CLAUDE_KEY

# opencode / 插件开关
OPENCODE_EXPERIMENTAL_BACKGROUND_SUBAGENTS=true
OPENCODE_ENABLE_EXA=false
OPENCODE_ENABLE_PARALLEL=true
EXA_API_KEY=REPLACE_WITH_EXA_KEY
